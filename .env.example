# Copy to .env and fill in. In GitHub Actions these are repository secrets.

# Kaggle API credentials (https://www.kaggle.com/settings -> Create New Token)
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_API_KEY=your-kaggle-api-key

# Private dataset holding full_history.csv — the pipeline's only state.
# Format: <username>/<dataset-slug>. Bootstrap it with `vienna-rentals seed`.
PRIVATE_KAGGLE_DATASET_SLUG=your-kaggle-username/vienna-rentals-full-history

# Public dataset receiving the processed export (Wohn-Ticket column added,
# internal columns removed).
KAGGLE_DATASET_SLUG=your-kaggle-username/vienna-rental-listings

# Telegram bot used to announce new listings (via @BotFather).
BOT_API_KEY=123456:your-telegram-bot-token
CHANNEL_ID=@your-channel-or-chat-id

# Optional: how many days back an Ad ID counts as "already seen" (default 30).
# DEDUP_WINDOW_DAYS=30
